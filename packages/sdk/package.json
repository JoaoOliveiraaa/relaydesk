{
  "name": "@relaydesk/sdk",
  "version": "0.0.1",
  "private": true,
  "description": "Foundation TypeScript SDK para integrações RelayDesk (cliente HTTP tipado, auth helpers).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "5.7.3"
  }
}
